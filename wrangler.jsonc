{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gptpro-gh-workbench",
  "main": "src/worker.js",
  "compatibility_date": "2026-04-28",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "gptpro-gh-workbench.eugnel.uk/*",
      "zone_name": "eugnel.uk"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "WORKBENCH_ACTION_KV",
      "id": "1ada5703d7884010a342468696b34622"
    }
  ]
}
